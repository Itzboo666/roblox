local rarityColors = {
    ["Legendary"] = tonumber("dfc010", 16),
    ["Secret"] = tonumber("a110df", 16)
}

-- Duplicate protection system
local lastHatches = {
    time = 0,
    pets = {}
}
local PROCESSING_LOCK = false
local COOLDOWN = 5 -- Increased to 5 seconds

game:GetService("ReplicatedStorage"):WaitForChild("Shared"):WaitForChild("Framework"):WaitForChild("Network"):WaitForChild("Remote"):WaitForChild("Event").OnClientEvent:Connect(function()
    if PROCESSING_LOCK or (os.time() - lastHatches.time) < COOLDOWN then return end
    PROCESSING_LOCK = true
    
    -- Wait for full hatch animation
    local hatchingGui = game:GetService("Players").LocalPlayer.PlayerGui:WaitForChild("ScreenGui")
    if not hatchingGui then return end
    local container = hatchingGui:WaitForChild("Hatching"):WaitForChild("Last")
    task.wait(6) -- Increased wait for slower animations

    local embeds = {}
    local currentPets = {}

    for _, instance in pairs(container:GetChildren()) do
        if instance:IsA("Frame") and instance.Name == "Template" then
            local rarity = instance:FindFirstChild("Rarity") and instance.Rarity.Text
            local petName = instance.Label.Text
            
            if petChances[petName] and rarityColors[rarity] and not currentPets[petName] then
                currentPets[petName] = true
                
                local formattedChance = tostring(petChances[petName]):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
                
                table.insert(embeds, {
                    title = "🚨 ULTRA RARE HATCH! 🚨",
                    description = string.format(
                        "**%s**\nRarity: %s\nChance: 1 in %s",
                        petName,
                        rarity,
                        formattedChance
                    ),
                    color = rarityColors[rarity],
                    thumbnail = {url = images[petName]},
                    footer = {text = os.date("Hatched at %I:%M:%S %p")}
                })
            end
        end
    end

    if #embeds > 0 then
        local success, response = pcall(function()
            return request({
                Url = webhook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({embeds = embeds})
            })
        end)

        if success and (response.StatusCode == 200 or response.StatusCode == 204) then
            lastHatches.time = os.time()
            print("Webhook sent successfully")
        else
            warn("Webhook failed:", response.StatusCode or "No response")
        end
    end

    PROCESSING_LOCK = false
    -- Clear memory after cooldown
    task.wait(COOLDOWN)
    lastHatches.pets = {}
end)


